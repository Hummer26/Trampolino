{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "trampolino",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-06-10",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "keep_vars": true,
  "vars": {
    "CONTACT_EMAIL": "plazaswiss@gmail.com",
    "RESEND_FROM_EMAIL": "Salto Trampolino <noreply@mail.saltotrampolino.ch>",
    "NEXT_PUBLIC_SITE_URL": "https://saltotrampolino.ch"
  },
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "routes": [
    {
      "pattern": "saltotrampolino.ch",
      "custom_domain": true
    },
    {
      "pattern": "www.saltotrampolino.ch",
      "custom_domain": true
    }
  ],
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "trampolino"
    }
  ],
  "observability": {
    "enabled": true
  }
}
